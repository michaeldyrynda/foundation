{
  "name": "foundation",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["client"],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "cd client && bunx vite",
    "build": "cd client && bun run build",
    "start": "NODE_ENV=production bun server/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun server/db/migrate.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.14",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4"
  }
}
